<%- include('../partials/mainHeader', { title: 'Interview Log — Resurge', activePage: 'interviewLog' }) %>

<main class="snap-container" id="snap-main" style="padding-top:62px;">

  <section class="snap-section il-hero-section">
    <div class="il-hero-center reveal-up">
      <div class="rsg-tag" style="margin-bottom:18px;"><span class="accent-dot"></span> Interview Analytics</div>
      <h1 class="il-hero-title">Interview Log.</h1>
      <p class="il-hero-caption">Track every interview, decode your performance, and build a roadmap to your next offer — powered by AI analysis.</p>
      <button id="il-start-btn" class="rsg-btn il-start-btn">Start Analyzing &nbsp;<i class="fa-solid fa-arrow-down"></i></button>
    </div>
  </section>

  <section class="snap-section il-form-section" id="il-form-section">
    <div class="il-form-wrap">

      <div class="il-progress-bar-wrap">
        <div class="il-progress-steps">
          <div class="il-step active" data-step="1"><span class="il-step-num">1</span><span class="il-step-label">Context</span></div>
          <div class="il-step-line"></div>
          <div class="il-step" data-step="2"><span class="il-step-num">2</span><span class="il-step-label">Prep</span></div>
          <div class="il-step-line"></div>
          <div class="il-step" data-step="3"><span class="il-step-num">3</span><span class="il-step-label">Technical</span></div>
          <div class="il-step-line"></div>
          <div class="il-step" data-step="4"><span class="il-step-num">4</span><span class="il-step-label">Comm.</span></div>
          <div class="il-step-line"></div>
          <div class="il-step" data-step="5"><span class="il-step-num">5</span><span class="il-step-label">Confidence</span></div>
        </div>
      </div>

      <form id="il-form" novalidate>

        <div class="il-page active" id="il-page-1">
          <div class="il-page-title">Interview Context</div>
          <div class="il-grid-2">
            <div class="il-field">
              <label class="rsg-label" for="interviewDate">Interview Date *</label>
              <input class="rsg-input" type="date" id="interviewDate" name="interviewDate" required>
            </div>
            <div class="il-field">
              <label class="rsg-label" for="companyName">Company Name *</label>
              <input class="rsg-input" type="text" id="companyName" name="companyName" placeholder="e.g. Google" required>
            </div>
            <div class="il-field">
              <label class="rsg-label" for="jobTitle">Job Title *</label>
              <input class="rsg-input" type="text" id="jobTitle" name="jobTitle" placeholder="e.g. Software Engineer" required>
            </div>
            <div class="il-field">
              <label class="rsg-label" for="interviewType">Interview Type *</label>
              <select class="rsg-input" id="interviewType" name="interviewType" required>
                <option value="">Select type...</option>
                <option value="Technical">Technical</option>
                <option value="HR">HR</option>
                <option value="Managerial">Managerial</option>
                <option value="Mixed">Mixed</option>
              </select>
            </div>
            <div class="il-field">
              <label class="rsg-label" for="interviewDuration">Duration (minutes) *</label>
              <input class="rsg-input" type="number" id="interviewDuration" name="interviewDuration" min="1" placeholder="e.g. 45" required>
            </div>
            <div class="il-field">
              <label class="rsg-label" for="numberOfRounds">Number of Rounds *</label>
              <input class="rsg-input" type="number" id="numberOfRounds" name="numberOfRounds" min="1" placeholder="e.g. 2" required>
            </div>
          </div>
          <div class="il-field" style="margin-top:20px;">
            <label class="rsg-label">Outcome *</label>
            <div class="il-radio-group">
              <label class="il-radio-label"><input type="radio" name="outcome" value="Selected" required> Selected</label>
              <label class="il-radio-label"><input type="radio" name="outcome" value="Rejected"> Rejected</label>
              <label class="il-radio-label"><input type="radio" name="outcome" value="Awaiting"> Awaiting</label>
            </div>
          </div>
        </div>

        <div class="il-page" id="il-page-2">
          <div class="il-page-title">Job & Preparation</div>
          <div class="il-field">
            <label class="rsg-label" for="jobDescription">Job Description *</label>
            <textarea class="rsg-input" id="jobDescription" name="jobDescription" rows="4" placeholder="Paste the job description here..." required></textarea>
          </div>
          <div class="il-grid-2">
            <div class="il-field">
              <label class="rsg-label">Core Skills Required *</label>
              <div class="il-tag-input-wrap" id="coreSkillsWrap">
                <div class="il-tags" id="coreSkillsTags"></div>
                <input class="il-tag-input" id="coreSkillsInput" placeholder="Type skill + Enter" autocomplete="off">
                <input type="hidden" name="coreSkillsRequired" id="coreSkillsHidden">
              </div>
            </div>
            <div class="il-field">
              <label class="rsg-label">Your Skills *</label>
              <div class="il-tag-input-wrap" id="yourSkillsWrap">
                <div class="il-tags" id="yourSkillsTags"></div>
                <input class="il-tag-input" id="yourSkillsInput" placeholder="Type skill + Enter" autocomplete="off">
                <input type="hidden" name="yourSkills" id="yourSkillsHidden">
              </div>
            </div>
          </div>
          <div class="il-field" style="margin-top:16px;">
            <label class="rsg-label">Preparation Level: <span id="prepLevelVal">3</span>/5</label>
            <input class="il-slider" type="range" id="preparationLevel" name="preparationLevel" min="1" max="5" value="3">
          </div>
          <div class="il-grid-2" style="margin-top:16px;">
            <div class="il-field">
              <label class="rsg-label">Mock Interviews Done? *</label>
              <div class="il-radio-group">
                <label class="il-radio-label"><input type="radio" name="mockInterviewsDone" value="true" required> Yes</label>
                <label class="il-radio-label"><input type="radio" name="mockInterviewsDone" value="false"> No</label>
              </div>
            </div>
            <div class="il-field">
              <label class="rsg-label">Compensation Discussed? *</label>
              <div class="il-radio-group">
                <label class="il-radio-label"><input type="radio" name="compensationDiscussed" value="true" required> Yes</label>
                <label class="il-radio-label"><input type="radio" name="compensationDiscussed" value="false"> No</label>
              </div>
            </div>
          </div>
        </div>

        <div class="il-page" id="il-page-3">
          <div class="il-page-title">Technical Performance</div>
          <div class="il-grid-2">
            <div class="il-field">
              <label class="rsg-label">Technical Skill Rating: <span id="techRatingVal">5</span>/10</label>
              <input class="il-slider" type="range" id="technicalSkillRating" name="technicalSkillRating" min="1" max="10" value="5">
            </div>
            <div class="il-field">
              <label class="rsg-label">Problem Solving Rating: <span id="probRatingVal">5</span>/10</label>
              <input class="il-slider" type="range" id="problemSolvingRating" name="problemSolvingRating" min="1" max="10" value="5">
            </div>
          </div>
          <div class="il-grid-2" style="margin-top:16px;">
            <div class="il-field">
              <label class="rsg-label">Were you able to solve questions? *</label>
              <div class="il-radio-group">
                <label class="il-radio-label"><input type="radio" name="solvedQuestions" value="Yes" required> Yes</label>
                <label class="il-radio-label"><input type="radio" name="solvedQuestions" value="Partially"> Partially</label>
                <label class="il-radio-label"><input type="radio" name="solvedQuestions" value="No"> No</label>
              </div>
            </div>
            <div class="il-field">
              <label class="rsg-label">Did you need hints? *</label>
              <div class="il-radio-group">
                <label class="il-radio-label"><input type="radio" name="neededHints" value="true" required> Yes</label>
                <label class="il-radio-label"><input type="radio" name="neededHints" value="false"> No</label>
              </div>
            </div>
          </div>
          <div class="il-field" style="margin-top:16px;">
            <label class="rsg-label" for="difficultyLevel">Difficulty Level *</label>
            <select class="rsg-input" id="difficultyLevel" name="difficultyLevel" required>
              <option value="">Select difficulty...</option>
              <option value="Easy">Easy</option>
              <option value="Medium">Medium</option>
              <option value="Hard">Hard</option>
            </select>
          </div>
          <div class="il-field" style="margin-top:16px;">
            <label class="rsg-label" for="technicalDescription">Technical Experience Description *</label>
            <textarea class="rsg-input" id="technicalDescription" name="technicalDescription" rows="3" placeholder="Describe your technical experience..." required></textarea>
          </div>
        </div>

        <div class="il-page" id="il-page-4">
          <div class="il-page-title">Communication & Behaviour</div>
          <div class="il-grid-2">
            <div class="il-field">
              <label class="rsg-label">Communication Rating: <span id="commRatingVal">5</span>/10</label>
              <input class="il-slider" type="range" id="communicationRating" name="communicationRating" min="1" max="10" value="5">
            </div>
            <div class="il-field">
              <label class="rsg-label">Behavioural Skill Rating: <span id="behavRatingVal">5</span>/10</label>
              <input class="il-slider" type="range" id="behaviouralRating" name="behaviouralRating" min="1" max="10" value="5">
            </div>
          </div>
          <div class="il-grid-3" style="margin-top:16px;">
            <div class="il-field">
              <label class="rsg-label">Explained approach clearly? *</label>
              <div class="il-radio-group">
                <label class="il-radio-label"><input type="radio" name="explainedClearly" value="true" required> Yes</label>
                <label class="il-radio-label"><input type="radio" name="explainedClearly" value="false"> No</label>
              </div>
            </div>
            <div class="il-field">
              <label class="rsg-label">Used real examples? *</label>
              <div class="il-radio-group">
                <label class="il-radio-label"><input type="radio" name="usedRealExamples" value="true" required> Yes</label>
                <label class="il-radio-label"><input type="radio" name="usedRealExamples" value="false"> No</label>
              </div>
            </div>
            <div class="il-field">
              <label class="rsg-label">Used STAR method? *</label>
              <div class="il-radio-group">
                <label class="il-radio-label"><input type="radio" name="usedStarMethod" value="true" required> Yes</label>
                <label class="il-radio-label"><input type="radio" name="usedStarMethod" value="false"> No</label>
              </div>
            </div>
          </div>
          <div class="il-field" style="margin-top:16px;">
            <label class="rsg-label" for="commDescription">Communication & Behaviour Description *</label>
            <textarea class="rsg-input" id="commDescription" name="commDescription" rows="3" placeholder="Describe your communication experience..." required></textarea>
          </div>
        </div>

        <div class="il-page" id="il-page-5">
          <div class="il-page-title">Confidence & Reflection</div>
          <div class="il-grid-2">
            <div class="il-field">
              <label class="rsg-label">Confidence Rating: <span id="confRatingVal">5</span>/10</label>
              <input class="il-slider" type="range" id="confidenceRating" name="confidenceRating" min="1" max="10" value="5">
            </div>
            <div class="il-field">
              <label class="rsg-label">Nervousness Level: <span id="nervRatingVal">5</span>/10</label>
              <input class="il-slider" type="range" id="nervousnessLevel" name="nervousnessLevel" min="1" max="10" value="5">
            </div>
          </div>
          <div class="il-grid-2" style="margin-top:12px;">
            <div class="il-field">
              <label class="rsg-label">Did you panic at any point? *</label>
              <div class="il-radio-group">
                <label class="il-radio-label"><input type="radio" name="panickedAtAnyPoint" value="true" required> Yes</label>
                <label class="il-radio-label"><input type="radio" name="panickedAtAnyPoint" value="false"> No</label>
              </div>
            </div>
            <div class="il-field">
              <label class="rsg-label">Overall Self Rating: <span id="selfRatingVal">5</span>/10</label>
              <input class="il-slider" type="range" id="overallSelfRating" name="overallSelfRating" min="1" max="10" value="5">
            </div>
          </div>
          <div class="il-field" style="margin-top:16px;">
            <label class="rsg-label" for="whatWentWell">What went well? *</label>
            <textarea class="rsg-input" id="whatWentWell" name="whatWentWell" rows="2" placeholder="Describe what went well..." required></textarea>
          </div>
          <div class="il-field">
            <label class="rsg-label" for="whatWentWrong">What went wrong? *</label>
            <textarea class="rsg-input" id="whatWentWrong" name="whatWentWrong" rows="2" placeholder="Describe what went wrong..." required></textarea>
          </div>
          <div class="il-field">
            <label class="rsg-label" for="whatToImprove">What would you improve? *</label>
            <textarea class="rsg-input" id="whatToImprove" name="whatToImprove" rows="2" placeholder="What would you do differently?" required></textarea>
          </div>
          <div class="il-optional-toggle" id="il-optional-toggle">
            <button type="button" class="il-optional-btn" id="il-show-optional"><i class="fa-solid fa-plus"></i> Optional Fields</button>
          </div>
          <div class="il-optional-fields" id="il-optional-fields" style="display:none;">
            <div class="il-optional-label">Optional Enhancements</div>
            <div class="il-grid-3">
              <div class="il-field">
                <label class="rsg-label">Interviewer asked follow-ups?</label>
                <div class="il-radio-group">
                  <label class="il-radio-label"><input type="radio" name="interviewerAskedFollowUps" value="true"> Yes</label>
                  <label class="il-radio-label"><input type="radio" name="interviewerAskedFollowUps" value="false"> No</label>
                </div>
              </div>
              <div class="il-field">
                <label class="rsg-label" for="timeTakenToSolve">Time to solve (min)</label>
                <input class="rsg-input" type="number" id="timeTakenToSolve" name="timeTakenToSolve" min="0" placeholder="e.g. 20">
              </div>
              <div class="il-field">
                <label class="rsg-label">Would you hire yourself?</label>
                <div class="il-radio-group">
                  <label class="il-radio-label"><input type="radio" name="wouldHireYourself" value="true"> Yes</label>
                  <label class="il-radio-label"><input type="radio" name="wouldHireYourself" value="false"> No</label>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="il-form-nav">
          <button type="button" class="rsg-btn rsg-btn-outline" id="il-prev-btn" style="display:none;"><i class="fa-solid fa-arrow-left"></i> &nbsp;Back</button>
          <div class="il-page-indicator" id="il-page-indicator">Page 1 of 5</div>
          <button type="button" class="rsg-btn" id="il-next-btn">Next &nbsp;<i class="fa-solid fa-arrow-right"></i></button>
          <button type="submit" class="rsg-btn il-submit-btn" id="il-submit-btn" style="display:none;"><i class="fa-solid fa-bolt"></i> &nbsp;Analyze Interview</button>
        </div>

      </form>

      <div class="il-loading" id="il-loading" style="display:none;">
        <div class="il-loading-inner">
          <div class="il-spinner"></div>
          <div class="il-loading-text">Analyzing your interview data...</div>
        </div>
      </div>
    </div>
  </section>

  <section class="snap-section il-dashboard-section hidden" id="il-dashboard">
    <div class="il-dash-inner">

      <div class="il-kpi-row">
        <div class="il-kpi-card" id="kpi-jobfit">
          <div class="il-kpi-icon"><i class="fa-solid fa-bullseye"></i></div>
          <div class="il-kpi-val" id="kpi-jobfit-val">--</div>
          <div class="il-kpi-label">Job Fit Score</div>
          <div class="il-kpi-sub">Resume vs Job Description</div>
        </div>
        <div class="il-kpi-card" id="kpi-perf">
          <div class="il-kpi-icon"><i class="fa-solid fa-chart-line"></i></div>
          <div class="il-kpi-val" id="kpi-perf-val">--</div>
          <div class="il-kpi-label">Interview Performance</div>
          <div class="il-kpi-sub">Technical + Comm + Behaviour</div>
        </div>
        <div class="il-kpi-card" id="kpi-conf">
          <div class="il-kpi-icon"><i class="fa-solid fa-shield-halved"></i></div>
          <div class="il-kpi-val" id="kpi-conf-val">--</div>
          <div class="il-kpi-label">Confidence Score</div>
          <div class="il-kpi-sub">Confidence, Nervousness & Self</div>
        </div>
        <div class="il-kpi-card" id="kpi-ready">
          <div class="il-kpi-icon"><i class="fa-solid fa-rocket"></i></div>
          <div class="il-kpi-val" id="kpi-ready-val">--</div>
          <div class="il-kpi-label">Readiness Score</div>
          <div class="il-kpi-sub">Prep + Confidence + Comm</div>
        </div>
      </div>

      <div class="il-dash-row-2">
        <div class="il-dash-card">
          <div class="il-dash-card-title"><i class="fa-solid fa-spider"></i> Skill Overview</div>
          <canvas id="il-radar-chart" height="280"></canvas>
        </div>
        <div class="il-dash-card">
          <div class="il-dash-card-title"><i class="fa-solid fa-chart-bar"></i> Overall Comparison</div>
          <canvas id="il-bar-chart" height="280"></canvas>
        </div>
      </div>

      <div class="il-dash-card il-ai-card">
        <div class="il-dash-card-title"><i class="fa-solid fa-brain"></i> AI Interview Feedback</div>
        <p class="il-ai-summary" id="il-ai-summary">--</p>
        <div class="il-ai-cols">
          <div>
            <div class="il-ai-section-label il-green"><i class="fa-solid fa-circle-check"></i> Strengths</div>
            <ul class="il-ai-list" id="il-strengths-list"></ul>
          </div>
          <div>
            <div class="il-ai-section-label il-red"><i class="fa-solid fa-triangle-exclamation"></i> Areas of Concern</div>
            <ul class="il-ai-list" id="il-concerns-list"></ul>
          </div>
        </div>
      </div>

      <div class="il-dash-row-2">
        <div class="il-dash-card">
          <div class="il-dash-card-title"><i class="fa-solid fa-arrow-trend-up"></i> Improvement Suggestions</div>
          <ul class="il-improve-list" id="il-improve-list"></ul>
        </div>
        <div class="il-dash-card">
          <div class="il-dash-card-title"><i class="fa-solid fa-chart-pie"></i> Skill Distribution</div>
          <canvas id="il-pie-chart" height="220"></canvas>
          <div class="il-pie-legend" id="il-pie-legend"></div>
        </div>
      </div>

      <div class="il-dash-card">
        <div class="il-dash-card-title"><i class="fa-solid fa-sliders"></i> Skill Proficiency</div>
        <div class="il-proficiency-grid" id="il-proficiency-grid"></div>
      </div>

      <div class="il-dash-row-2">
        <div class="il-dash-card">
          <div class="il-dash-card-title"><i class="fa-solid fa-chart-column"></i> Skill Breakdown</div>
          <canvas id="il-breakdown-chart" height="260"></canvas>
        </div>
        <div class="il-dash-card">
          <div class="il-dash-card-title"><i class="fa-solid fa-chart-line"></i> Skills Comparison</div>
          <canvas id="il-line-chart" height="260"></canvas>
        </div>
      </div>

      <div class="il-new-analysis-wrap">
        <button class="rsg-btn" id="il-new-analysis-btn"><i class="fa-solid fa-rotate-left"></i> &nbsp;New Analysis</button>
      </div>

    </div>
  </section>

  <footer class="snap-section rsg-footer rsg-footer-wrap">
    <video autoplay muted loop playsinline class="footer-video" src="/assets/footer_animation.mp4"></video>
    <div class="footer-content-wrap">
      <div class="footer-grid">
        <div><span class="footer-brand">RESURGE</span>
          <p class="footer-tagline">Stop guessing. Start analyzing and visualizing your career path.</p>
          <a href="/signUp" class="rsg-btn rsg-btn-footer">Join Now →</a>
        </div>
        <div>
          <div class="footer-col-label">Platform</div>
          <div class="footer-col-list">
            <a href="/resumeScore" class="footer-col-link">Resume Score</a>
            <a href="/interviewLog" class="footer-col-link">Interview Log</a>
          </div>
        </div>
        <div>
          <div class="footer-col-label">Legal</div>
          <div class="footer-col-list">
            <a href="/404" class="footer-col-link">Privacy Policy</a>
            <a href="/404" class="footer-col-link">Terms Of Use</a>
          </div>
        </div>
        <div>
          <div class="footer-col-label">Connect</div>
          <div class="footer-col-list">
            <a href="/404" class="footer-col-link"><i class="fa-brands fa-github"></i> &nbsp;GitHub</a>
            <a href="/404" class="footer-col-link"><i class="fa-brands fa-linkedin"></i> &nbsp;LinkedIn</a>
          </div>
        </div>
      </div>
      <div class="footer-marquee-strip">
        <div class="footer-marquee-track"><span class="footer-marquee-word">ANALYZE</span><span class="footer-marquee-dot"></span><span class="footer-marquee-word">VISUALIZE</span><span class="footer-marquee-dot"></span><span class="footer-marquee-word">RESURGE</span><span class="footer-marquee-dot"></span><span class="footer-marquee-word">IMPROVE</span><span class="footer-marquee-dot"></span><span class="footer-marquee-word">TRACK</span><span class="footer-marquee-dot"></span><span class="footer-marquee-word">GROW</span><span class="footer-marquee-dot"></span><span class="footer-marquee-word">ANALYZE</span><span class="footer-marquee-dot"></span><span class="footer-marquee-word">VISUALIZE</span><span class="footer-marquee-dot"></span><span class="footer-marquee-word">RESURGE</span><span class="footer-marquee-dot"></span></div>
      </div>
      <div class="footer-bottom-bar"><span class="footer-copy">Resurge Analytics &copy; 2026</span><span class="footer-copy-right">Built for Career Growth</span></div>
    </div>
  </footer>

</main>

<div class="il-dialog-overlay" id="il-dialog-overlay" style="display:none;">
  <div class="il-dialog">
    <div class="il-dialog-icon"><i class="fa-solid fa-circle-exclamation"></i></div>
    <div class="il-dialog-title">Empty Required Fields</div>
    <div class="il-dialog-body" id="il-dialog-body">Please fill in all required fields before continuing.</div>
    <button class="rsg-btn" id="il-dialog-close">OK</button>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script src="/js/interview-log.js"></script>
<%- include('../partials/mainFooter') %>
