<%- include('../partials/mainHeader', { title: 'Resurge: Interview Analytics', activePage: 'home' }) %>

    <main class="snap-container" id="snap-main">

        <section class="snap-section hero-section">
            <div class="rsg-container hero-container">
                <div class="hero-orbs-wrap">
                    <div class="hero-orb hero-orb-1"><i class="fa-solid fa-chart-simple"></i></div>
                    <div class="hero-orb hero-orb-2"><i class="fa-solid fa-file-lines"></i></div>
                    <div class="hero-orb hero-orb-3"><i class="fa-solid fa-brain"></i></div>
                    <div class="hero-orb hero-orb-4"><i class="fa-solid fa-magnifying-glass-chart"></i></div>
                    <div class="hero-orb hero-orb-5"><i class="fa-solid fa-code"></i></div>
                    <div class="hero-orb hero-orb-6"><i class="fa-regular fa-lightbulb"></i></div>
                    <div class="hero-orb hero-orb-7"><i class="fa-solid fa-star"></i></div>
                    <div class="hero-orb hero-orb-8"><i class="fa-solid fa-rocket"></i></div>
                </div>
                <div class="hero-center">
                    <div class="rsg-tag reveal-up"><span class="accent-dot"></span> Next-Gen Interview Analytics</div>
                    <h1 class="hero-title reveal-up delay-100">RESURGE</h1>
                    <p class="hero-caption reveal-up delay-200">The all-in-one platform to analyze your resume, log interview experiences, and visualize your path to success.</p>
                    <div class="hero-actions reveal-up delay-300">
                        <a href="/resumeScore" class="rsg-btn">Start Analyzing <i class="fa-solid fa-arrow-right"></i></a>
                        <a href="/signUp" class="rsg-btn rsg-btn-outline">Get Started Free</a>
                    </div>
                </div>
            </div>
        </section>

        <section class="snap-section tagline-section">
            <div class="rsg-container">
                <span class="section-label tagline-label">The Resurge Philosophy</span>
                <h2 class="tagline-heading">Stop Guessing.<br>Start <span id="typing-word">Visualizing</span> Your Career.</h2>
                <p class="tagline-body">Turn every interview "No" into a data point. Resurge helps you track patterns and refine your strategy for the roles you actually want.</p>
                <div class="tagline-stats">
                    <div>
                        <div class="tagline-stat-num">10K+</div>
                        <div class="tagline-stat-lbl">Resumes Analyzed</div>
                    </div>
                    <div class="tagline-divider"></div>
                    <div>
                        <div class="tagline-stat-num">94%</div>
                        <div class="tagline-stat-lbl">Improvement Rate</div>
                    </div>
                    <div class="tagline-divider"></div>
                    <div>
                        <div class="tagline-stat-num">3x</div>
                        <div class="tagline-stat-lbl">Faster Job Offers</div>
                    </div>
                </div>
            </div>
        </section>

        <section class="snap-section">
            <div class="rsg-container">
                <div class="features-header">
                    <span class="section-label">Platform Features</span>
                    <h2 class="features-heading">Everything you need<br>to Succeed.</h2>
                </div>
                <div class="features-grid reveal-up">
                    <div class="feature-card">
                        <div class="feature-icon"><i class="fa-solid fa-file-circle-check"></i></div>
                        <div>
                            <div class="feature-title">ATS Score Calculator</div>
                            <p class="feature-desc">Upload your resume to receive an instant compatibility score based on the data structures recruiters look for.</p>
                        </div>
                        <a href="/resumeScore" class="rsg-btn rsg-btn-outline feature-btn">Analyze Resume →</a>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon"><i class="fa-solid fa-pen-to-square"></i></div>
                        <div>
                            <div class="feature-title">Interview Logging</div>
                            <p class="feature-desc">Maintain a detailed record of every round, question, and feedback point you receive across all interviews.</p>
                        </div>
                        <a href="/404" class="rsg-btn rsg-btn-outline feature-btn">Log Interview →</a>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon"><i class="fa-solid fa-chart-column"></i></div>
                        <div>
                            <div class="feature-title">Interview Insights</div>
                            <p class="feature-desc">Visualize your progress with data-driven reports, applying the same logic as your AI-based projects.</p>
                        </div>
                        <a href="/404" class="rsg-btn rsg-btn-outline feature-btn">View Analytics →</a>
                    </div>
                </div>
            </div>
        </section>

        <section class="snap-section">
            <div class="rsg-container ai-grid">
                <div class="ai-panel reveal-left">
                    <div class="ai-panel-header">
                        <div class="ai-icon-box"><i class="fa-solid fa-brain"></i></div>
                        <div>
                            <div class="ai-panel-title">AI Analysis in Progress</div>
                            <div class="ai-panel-sub">Processing your interview history...</div>
                        </div>
                    </div>
                    <div class="ai-insight">
                        <div class="ai-insight-label">Resume Weakness</div>
                        Your experience section is lacking quantifiable metrics matching the target role. Add impact numbers to 3+ bullet points.
                    </div>
                    <div class="ai-insight">
                        <div class="ai-insight-label">Interview Feedback</div>
                        You struggled with System Design scaling questions. Focus on load balancers and horizontal scaling patterns.
                    </div>
                    <div class="ai-insight ai-insight-last">
                        <div class="ai-insight-label">ATS Score</div>
                        Current score: <strong>78/100</strong> — 14/18 keywords matched. Missing: Docker, K8s, CI/CD.
                    </div>
                </div>
                <div class="reveal-right delay-200">
                    <span class="section-label">Meet Resurge AI</span>
                    <h2 class="ai-section-heading">Your Personal Career Co-Pilot.</h2>
                    <p class="ai-section-body">Resurge AI securely analyzes your entire interview history to understand exactly why you were rejected, offering tailored improvement plans.</p>
                    <ul class="ai-feature-list">
                        <li class="ai-feature-item"><span class="ai-feature-num">01</span><span class="ai-feature-name">Interview Autopsy</span><span class="ai-feature-arrow">→</span></li>
                        <li class="ai-feature-item"><span class="ai-feature-num">02</span><span class="ai-feature-name">Smart Resume Review</span><span class="ai-feature-arrow">→</span></li>
                        <li class="ai-feature-item"><span class="ai-feature-num">03</span><span class="ai-feature-name">Improvement Roadmap</span><span class="ai-feature-arrow">→</span></li>
                    </ul>
                </div>
            </div>
        </section>

        <section class="snap-section">
            <div class="rsg-container workflow-grid">
                <div class="reveal-left">
                    <span class="section-label">The Success Loop</span>
                    <h2 class="workflow-heading">Log Details.<br>Get Insights.</h2>
                    <p class="workflow-body">Stop losing valuable feedback. Resurge turns your interview experiences into a step-by-step roadmap for your next offer.</p>
                    <a href="/interviewLog" class="rsg-btn workflow-btn">Start Logging →</a>
                </div>
                <div class="reveal-right delay-200" id="roadmap-section">
                    <div class="roadmap-line">
                        <div class="roadmap-step"><div class="roadmap-node"><div class="roadmap-dot">01</div><div class="roadmap-connector"></div></div><div class="roadmap-content"><div class="roadmap-title">Log the Interview</div><div class="roadmap-desc">Record every question, company, role, and feedback immediately after each round.</div></div></div>
                        <div class="roadmap-step"><div class="roadmap-node"><div class="roadmap-dot">02</div><div class="roadmap-connector"></div></div><div class="roadmap-content"><div class="roadmap-title">Upload Your Resume</div><div class="roadmap-desc">Submit your latest resume for an instant ATS compatibility and keyword audit.</div></div></div>
                        <div class="roadmap-step"><div class="roadmap-node"><div class="roadmap-dot">03</div><div class="roadmap-connector"></div></div><div class="roadmap-content"><div class="roadmap-title">AI Identifies Gaps</div><div class="roadmap-desc">Resurge AI cross-references your logs and resume to pinpoint exact failure patterns.</div></div></div>
                        <div class="roadmap-step"><div class="roadmap-node"><div class="roadmap-dot">04</div><div class="roadmap-connector"></div></div><div class="roadmap-content"><div class="roadmap-title">Get Your Action Plan</div><div class="roadmap-desc">Receive a tailored improvement roadmap with priority skill gaps and quick wins.</div></div></div>
                        <div class="roadmap-step"><div class="roadmap-node"><div class="roadmap-dot">05</div><div class="roadmap-connector"></div></div><div class="roadmap-content"><div class="roadmap-title">Land the Offer</div><div class="roadmap-desc">Apply the plan, track improvement, and re-enter the market stronger every cycle.</div></div></div>
                    </div>
                </div>
            </div>
        </section>

        <section class="snap-section">
            <div class="rsg-container perf-grid">
                <div class="reveal-left">
                    <span class="section-label">Performance Analysis</span>
                    <h2 class="perf-section-heading">Track Your Growth<br>Consistently.</h2>
                    <p class="perf-section-body">Visualize your progression across interview rounds. Identify patterns, double down on strengths, and systematically eliminate weaknesses.</p>
                    <div class="perf-meters-wrap" id="perf-meters">
                        <div class="perf-stat"><div class="perf-icon"><i class="fa-solid fa-chart-pie"></i></div><span class="perf-label">Success Rate by Type</span><div class="perf-bar-track"><div class="perf-bar-fill perf-bar-fill-red" data-width="72"></div></div><span class="perf-val">72%</span></div>
                        <div class="perf-stat"><div class="perf-icon"><i class="fa-solid fa-tags"></i></div><span class="perf-label">Frequent Topics Tracked</span><div class="perf-bar-track"><div class="perf-bar-fill perf-bar-fill-blue" data-width="58"></div></div><span class="perf-val">58%</span></div>
                        <div class="perf-stat"><div class="perf-icon"><i class="fa-solid fa-arrow-trend-up"></i></div><span class="perf-label">Skill Gap Closed Over Time</span><div class="perf-bar-track"><div class="perf-bar-fill perf-bar-fill-green" data-width="89"></div></div><span class="perf-val">89%</span></div>
                    </div>
                </div>
                <div class="reveal-right delay-200">
                    <div class="perf-chart-card">
                        <div class="perf-chart-header">
                            <div class="perf-chart-title">Overall Competency Score</div>
                            <div class="perf-chart-growth">↑ +24% Growth</div>
                        </div>
                        <div class="bar-chart">
                            <div class="chart-grid-line chart-grid-25"></div>
                            <div class="chart-grid-line chart-grid-50"></div>
                            <div class="chart-grid-line chart-grid-75"></div>
                            <div class="bar-col bar-h-25"><div class="bar-tip">Week 1</div></div>
                            <div class="bar-col bar-h-50"><div class="bar-tip">Week 2</div></div>
                            <div class="bar-col bar-h-35"><div class="bar-tip">Week 3</div></div>
                            <div class="bar-col bar-h-72"><div class="bar-tip">Week 4</div></div>
                            <div class="bar-col bar-h-100"><div class="bar-tip">Week 5</div></div>
                        </div>
                        <div class="chart-labels"><span>Wk 1</span><span>Wk 2</span><span>Wk 3</span><span>Wk 4</span><span>Wk 5</span></div>
                    </div>
                </div>
            </div>
        </section>

